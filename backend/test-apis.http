### =============================================================
### Reseller Management System - API Test Suite
### Base URL: http://localhost:8080
### =============================================================
### วิธีใช้: รันตามลำดับจากบนลงล่าง
###   1. Admin Login → ได้ adminToken
###   2. Register Reseller → รอ Admin Approve
###   3. Admin Approve Reseller
###   4. Reseller Login → ได้ resellerToken
###   5. ทดสอบ Flow ต่างๆ
### =============================================================


# ================================================================
# [A] AUTH — Login & Register
# ================================================================

### A1: Admin Login (password: admin123456)
POST http://localhost:8080/login
Content-Type: application/json

{
  "email": "admin@bootcamp.com",
  "password": "admin123456"
}

> {%
    client.global.set("adminToken", response.body.token);
    client.log("Admin Token saved: " + response.body.token);
    client.log("Role: " + response.body.role);
%}

###

### A2: Reseller Register (รอ Admin Approve ก่อน login ได้)
POST http://localhost:8080/register
Content-Type: application/json

{
  "name": "Jane Doe",
  "email": "jane@example.com",
  "phone": "0812345678",
  "password": "password123",
  "confirmPassword": "password123",
  "shopName": "Jane Shop",
  "address": "123 Bangkok"
}

###

### A3: Reseller Login (ต้อง approved ก่อน)
POST http://localhost:8080/login
Content-Type: application/json

{
  "email": "jane@example.com",
  "password": "password123"
}

> {%
    client.global.set("resellerToken", response.body.token);
    client.global.set("shopSlug", response.body.shop ? response.body.shop.shopSlug : "jane-shop");
    client.log("Reseller Token saved: " + response.body.token);
    client.log("Role: " + response.body.role);
%}

###


# ================================================================
# [B] ADMIN — Reseller Management
# ================================================================

### B1: List All Resellers (pending first)
GET http://localhost:8080/admin/resellers
Authorization: Bearer {{adminToken}}

###

### B2: Approve Reseller (เปลี่ยน {id} เป็น ID ของ Reseller)
POST http://localhost:8080/admin/reseller/2/status?status=approved
Authorization: Bearer {{adminToken}}

###

### B3: Reject Reseller
POST http://localhost:8080/admin/reseller/2/status?status=rejected
Authorization: Bearer {{adminToken}}

###


# ================================================================
# [C] ADMIN — Product Management
# ================================================================

### C1: List All Products (paginated)
GET http://localhost:8080/admin/products?page=0&size=10
Authorization: Bearer {{adminToken}}

###

### C2: Add Product (multipart/form-data — ใช้ Postman หรือ curl)
### ตัวอย่าง curl:
### curl -X POST http://localhost:8080/admin/products/add \
###   -H "Authorization: Bearer <adminToken>" \
###   -F "name=สินค้าทดสอบ" \
###   -F "description=รายละเอียดสินค้า" \
###   -F "costPrice=100" \
###   -F "minPrice=120" \
###   -F "stock=50" \
###   -F "image=@/path/to/image.jpg"
# POST http://localhost:8080/admin/products/add
# Authorization: Bearer {{adminToken}}

###

### C3: Edit Product (เปลี่ยน {id})
### (multipart/form-data เช่นเดียวกับ Add)
# PUT http://localhost:8080/admin/products/edit/1
# Authorization: Bearer {{adminToken}}

###

### C4: Delete Product
DELETE http://localhost:8080/admin/products/delete/1
Authorization: Bearer {{adminToken}}

###


# ================================================================
# [D] ADMIN — Order Management
# ================================================================

### D1: List All Orders (paginated)
GET http://localhost:8080/admin/orders?page=0&size=10
Authorization: Bearer {{adminToken}}

###

### D2: Update Order Status → shipped (เปลี่ยน orderId)
POST http://localhost:8080/admin/orders/status?status=shipped
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "orderId": 1
}

###

### D3: Update Order Status → completed
POST http://localhost:8080/admin/orders/status?status=completed
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "orderId": 1
}

###


# ================================================================
# [E] ADMIN — Dashboard
# ================================================================

### E1: Dashboard Statistics
GET http://localhost:8080/admin/dashboard
Authorization: Bearer {{adminToken}}

###


# ================================================================
# [F] RESELLER — Catalog (สินค้าจาก Admin)
# ================================================================

### F1: View All Products in Catalog
GET http://localhost:8080/reseller/catalog
Authorization: Bearer {{resellerToken}}

###

### F2: Add Product to My Shop (เลือก productId จาก catalog)
POST http://localhost:8080/reseller/catalog/select
Authorization: Bearer {{resellerToken}}
Content-Type: application/json

{
  "productId": 1,
  "sellingPrice": 150
}

###


# ================================================================
# [G] RESELLER — Shop Products
# ================================================================

### G1: View My Shop Products
GET http://localhost:8080/reseller/products?page=0&size=10
Authorization: Bearer {{resellerToken}}

###

### G2: Edit Selling Price (เปลี่ยน {id} เป็น shop_product id)
PATCH http://localhost:8080/reseller/products/1
Authorization: Bearer {{resellerToken}}
Content-Type: application/json

{
  "sellingPrice": 180
}

###

### G3: Remove Product from My Shop
DELETE http://localhost:8080/reseller/products/1
Authorization: Bearer {{resellerToken}}

###


# ================================================================
# [H] RESELLER — Orders
# ================================================================

### H1: View My Orders (paginated)
GET http://localhost:8080/reseller/orders?page=0&size=10
Authorization: Bearer {{resellerToken}}

###


# ================================================================
# [I] RESELLER — Wallet
# ================================================================

### I1: Wallet Balance + Recent History
GET http://localhost:8080/reseller/wallet
Authorization: Bearer {{resellerToken}}

###

### I2: Full Wallet History (paginated)
GET http://localhost:8080/reseller/wallet/logs?page=0&size=10
Authorization: Bearer {{resellerToken}}

###


# ================================================================
# [J] RESELLER — Dashboard
# ================================================================

### J1: Reseller Dashboard Stats
GET http://localhost:8080/reseller/dashboard
Authorization: Bearer {{resellerToken}}

###


# ================================================================
# [K] CUSTOMER — Shop & Checkout (Public, No Auth)
# ================================================================

### K1: View Shop by Slug
GET http://localhost:8080/shop/jane-shop

###

### K2: Customer Checkout
POST http://localhost:8080/shop/jane-shop/checkout
Content-Type: application/json

{
  "customerName": "John Smith",
  "customerPhone": "0987654321",
  "customerAddress": "456 Sukhumvit Rd, Bangkok",
  "items": [
    {
      "productId": 1,
      "quantity": 2
    }
  ]
}

> {%
    if (response.body.orderId) {
        client.global.set("orderId", response.body.orderId);
        client.log("Order ID saved: " + response.body.orderId);
        client.log("Order Number: " + response.body.orderNumber);
    }
%}

###

### K3: Simulate Payment (เปลี่ยน orderId)
POST http://localhost:8080/shop/jane-shop/payment/{{orderId}}

###

### K4: View Order Detail
GET http://localhost:8080/shop/jane-shop/order/{{orderId}}

###

### K5: Track Order by Order Number
GET http://localhost:8080/track-order?orderNumber=ORD-123456789

###
